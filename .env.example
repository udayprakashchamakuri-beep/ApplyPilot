# Never commit real API keys. Copy this file to .env in a backend environment.

# AI resume analysis and tailoring provider
FEATHERLESS_API_KEY=

# Crawling fallback for company career pages
FIRECRAWL_API_KEY=

# Optional job-source APIs
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
SMARTRECRUITERS_API_KEY=
BRIGHTDATA_API_KEY=
APIFY_TOKEN=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Optional server-side calendar auto-create (used by /api/apply)
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata

# Local backend
PORT=8787
CORS_ORIGIN=http://localhost:8787,http://127.0.0.1:8787

# Optional source configuration. If these are empty, the backend uses a small live default set.
# JSON is preferred. Examples:
# GREENHOUSE_BOARDS=[{"boardToken":"airbnb","company":"Airbnb"}]
# LEVER_ACCOUNTS=[{"account":"plaid","company":"Plaid"}]
# ASHBY_BOARDS=[{"boardName":"linear","company":"Linear"}]
GREENHOUSE_BOARDS=[]
LEVER_ACCOUNTS=[]
ASHBY_BOARDS=[]

# Company pages for Firecrawl fallback.
# COMPANY_CAREER_URLS=[{"url":"https://example.com/careers","company":"Example"}]
COMPANY_CAREER_URLS=[]
